# Create a Google Cloud service account with the Google Drive API enabled. Every target Drive
# folder (including one selected in the app) must be shared with the service-account email address.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Optional default when the sender has not selected a folder in Settings.
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id
